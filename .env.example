# ===========================
# SolSwap — Environment Config
# ===========================

# ── REQUIRED (app crashes on startup if missing) ──────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
FEE_WALLET_ADDRESS=YourSolanaWalletAddressForFeeCollection

# ── IMPORTANT (defaults provided, but should be set in production) ─────────────
JUPITER_API_URL=https://api.jup.ag/swap/v1
JUPITER_API_KEY=your_jupiter_api_key_from_portal_jup_ag
PLATFORM_FEE_BPS=50
NODE_ENV=production
DATABASE_URL=file:./data/prod.db
API_PORT=3001
CORS_ORIGIN=https://your-app.vercel.app
MINIAPP_URL=https://your-app.vercel.app
LOG_LEVEL=info

# ── Privy (Embedded Wallets) ──────────────────────────────────────────────────
PRIVY_APP_ID=your_privy_app_id

# ── LI.FI (Cross-Chain) — register at portal.li.fi for integrator fees ────────
# LIFI_API_KEY=your_lifi_api_key

# ── Helius (Receive Tracking + RPC) ──────────────────────────────────────────
HELIUS_API_KEY=your_helius_api_key
HELIUS_WEBHOOK_SECRET=your_random_webhook_secret

# ── Moralis (EVM Portfolio) — free at moralis.io ──────────────────────────────
# MORALIS_API_KEY=your_moralis_api_key

# ── Referral ──────────────────────────────────────────────────────────────────
REFERRAL_FEE_SHARE_PERCENT=25

# ── Phase 4 (not needed yet) ─────────────────────────────────────────────────
# GEMINI_API_KEY=your_gemini_api_key
